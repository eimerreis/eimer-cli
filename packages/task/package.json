{
  "name": "@scripts/task",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A CLI for Azure DevOps task workflows",
  "author": "",
  "exports": {
    ".": "./src/index.ts",
    "./commands": "./src/commands/index.ts"
  },
  "bin": {
    "task": "./dist/index.js"
  },
  "scripts": {
    "postinstall": "bunli generate",
    "dev": "bun run src/index.ts",
    "build": "bunli build --native --outfile ../../bin/task",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bunli/core": "latest",
    "@scripts/config": "workspace:*",
    "@scripts/ui": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bunli/test": "latest",
    "@types/bun": "latest",
    "bunli": "latest",
    "typescript": "^5.0.0"
  },
  "bunli": {
    "entry": "./src/index.ts",
    "outDir": "./dist"
  }
}
