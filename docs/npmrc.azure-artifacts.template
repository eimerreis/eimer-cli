@tapio:registry=https://pkgs.dev.azure.com/<org>/<project>/_packaging/<feed>/npm/registry/
always-auth=true

; For local dev with personal access token (Packaging Read scope):
; //pkgs.dev.azure.com/<org>/<project>/_packaging/<feed>/npm/registry/:_authToken=<PAT>

; For CI with Azure DevOps OAuth token:
; //pkgs.dev.azure.com/<org>/<project>/_packaging/<feed>/npm/registry/:_authToken=${SYSTEM_ACCESSTOKEN}
