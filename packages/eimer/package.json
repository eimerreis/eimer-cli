{
  "name": "@scripts/eimer",
  "version": "0.1.0",
  "type": "module",
  "description": "Meta CLI for all scripts packages",
  "author": "",
  "bin": {
    "eimer": "./dist/index.js"
  },
  "scripts": {
    "postinstall": "bunli generate",
    "dev": "bun run src/index.ts",
    "build": "bunli build --native --outfile ../../bin/eimer",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bunli/core": "latest",
    "@scripts/config": "0.1.0",
    "@scripts/pipeline": "0.1.0",
    "@scripts/pr": "0.1.0",
    "@scripts/release": "0.1.0",
    "@scripts/task": "0.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bunli/test": "latest",
    "@types/bun": "latest",
    "bunli": "latest",
    "typescript": "^5.0.0"
  },
  "bunli": {
    "entry": "./src/index.ts",
    "outDir": "./dist"
  }
}
